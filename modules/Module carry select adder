module top_module(
    input [31:0] a,
    input [31:0] b,
    output [31:0] sum
);

wire carry;
wire [15:0] sum0;
wire [15:0] sum1;
wire cout0, cout1;

add16 lower_adder (
    a[15:0],
    b[15:0],
    1'b0,
    sum[15:0],
    carry
);

add16 upper_adder_cin0 (
    a[31:16],
    b[31:16],
    1'b0,
    sum0,
    cout0
);

add16 upper_adder_cin1 (
    a[31:16],
    b[31:16],
    1'b1,
    sum1,
    cout1
);

assign sum[31:16] = carry ? sum1 : sum0;

endmodule
